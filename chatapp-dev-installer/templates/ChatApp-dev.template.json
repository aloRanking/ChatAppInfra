    "ResponseMappingTemplate": "\n\n{\n  \"messageId\": \"$util.autoId()\",\n  \"roomId\": \"$ctx.args.roomId\",\n  \"senderUserId\": \"$ctx.identity.sub\",\n  \"senderUsername\": \"$ctx.identity.username\",\n  \"content\": \"$ctx.args.content\",\n  \"createdAt\": \"$util.time.nowISO8601()\"\n}\n",
